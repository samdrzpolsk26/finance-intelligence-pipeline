# ============================================================
# Finance Intelligence Pipeline — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=finance_db

# --- Pipeline Settings ---
# Folder where new bank PDFs are dropped for auto-processing
PDF_WATCH_FOLDER=./data/inbox

# Folder for processed PDFs (moved after successful ingestion)
PDF_ARCHIVE_FOLDER=./data/archive

# How often the scheduler checks for new PDFs (in minutes)
SCHEDULER_INTERVAL_MINUTES=60

# --- ML Settings ---
# Retrain model after this many new transactions
ML_RETRAIN_THRESHOLD=30

# --- Notifications (optional, leave blank to disable) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFY_EMAIL=your_email@gmail.com

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./outputs/pipeline.log

# --- Bank Format ---
# Currently supported: erste_poland
BANK_FORMAT=erste_poland
